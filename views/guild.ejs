<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600&family=Crimson+Pro:ital,wght@0,300;0,400;1,300&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
html,body{margin:0;padding:0;background:#0e0c09}
.stage{
  height:520px;
  background:#0e0c09;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:3rem 2rem 2.5rem;
  position:relative;overflow:hidden;
  border-radius:var(--border-radius-lg);
}
.particles{position:absolute;inset:0;pointer-events:none}
.chapter{
  display:flex;flex-direction:column;align-items:center;
  gap:1rem;text-align:center;position:relative;z-index:2;
  flex:1;justify-content:center;
}
.chapter-num{
  font-family:'Cinzel',serif;font-size:11px;letter-spacing:0.22em;
  text-transform:uppercase;color:#7a6230;
  opacity:0;transform:translateY(6px);
  transition:opacity 0.9s ease,transform 0.9s ease;
}
.chapter-title{
  font-family:'Cinzel',serif;font-size:28px;font-weight:500;
  color:#e8cc80;letter-spacing:0.08em;
  opacity:0;transform:translateY(8px);
  transition:opacity 1.1s ease 0.2s,transform 1.1s ease 0.2s;
  line-height:1.2;
}
.chapter-body{
  font-family:'Crimson Pro',serif;font-size:16px;font-style:italic;
  color:#a09070;letter-spacing:0.02em;
  opacity:0;transform:translateY(6px);
  transition:opacity 1s ease 0.5s,transform 1s ease 0.5s;
  max-width:380px;line-height:1.6;
}
.chapter.visible .chapter-num,
.chapter.visible .chapter-title,
.chapter.visible .chapter-body{opacity:1;transform:translateY(0)}
.sep{
  width:40px;height:0.5px;background:#c9a84c;
  opacity:0;transition:opacity 1s ease 0.35s;
  margin:0 auto;
}
.chapter.visible .sep{opacity:0.4}
.nav{
  display:flex;gap:10px;align-items:center;
  flex-shrink:0;position:relative;z-index:2;padding-bottom:0.5rem;
}
.pip-nav{
  width:6px;height:6px;border-radius:50%;
  border:0.5px solid #7a6230;background:transparent;
  cursor:pointer;transition:background 0.3s,border-color 0.3s;
}
.pip-nav.active{background:#c9a84c;border-color:#c9a84c}
.nav-btn{
  font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.16em;
  text-transform:uppercase;color:#7a6230;background:none;
  border:0.5px solid #3a2e18;border-radius:var(--border-radius-md);
  padding:7px 16px;cursor:pointer;
  transition:color 0.2s,border-color 0.2s;
}
.nav-btn:hover{color:#c9a84c;border-color:#7a6230}
.nav-btn:disabled{opacity:0.2;cursor:default}
.progress-line{
  position:absolute;bottom:0;left:0;height:1px;
  background:#c9a84c;opacity:0.25;
  transition:width 0.6s ease;
}
.glyph{
  font-family:'Cinzel',serif;font-size:32px;color:#3a2e18;
  opacity:0;transform:scale(0.8);
  transition:opacity 1.2s ease 0.1s,transform 1.2s ease 0.1s;
  line-height:1;margin-bottom:0.25rem;
}
.chapter.visible .glyph{opacity:1;transform:scale(1)}
</style>

<div class="stage" id="stage">
  <canvas class="particles" id="particles-canvas"></canvas>
  <div class="chapter" id="chapter-display">
    <div class="glyph" id="glyph"></div>
    <div class="chapter-num" id="ch-num"></div>
    <div class="chapter-title" id="ch-title"></div>
    <div class="sep"></div>
    <div class="chapter-body" id="ch-body"></div>
  </div>
  <div class="nav">
    <button class="nav-btn" id="prev-btn" disabled onclick="go(-1)">&#8592;</button>
    <div id="pips" style="display:flex;gap:8px;align-items:center"></div>
    <button class="nav-btn" id="next-btn" onclick="go(1)">&#8594;</button>
  </div>
  <div class="progress-line" id="progress-line"></div>
</div>

<script>
const chapters=[
  {num:'Prologue',glyph:'⚔',title:'The Adventurers Guild',body:'A system for those seeking to hone their skills, and turn their goals into grand quests.'},
  {num:'Chapter I',glyph:'⚜',title:'Assemble your guild',body:'Rally your allies. Two or three companions to journey with you. Every great adventure begins with the right party.'},
  {num:'Chapter II',glyph:'◈',title:'Choose your quests',body:'Imageine your best future. Write it. Shape it into quests worth pursuing, and turn those quests into actions.'},
  {num:'Chapter III',glyph:'◇',title:'Level up your skills',body:'Assess your strengths and discover your weaknesses. Track your habits. Watch your ability scores rise as you journey.'},
  {num:'Chapter IV',glyph:'⬡',title:'Work together',body:'Weekly check-ins. Monthly meetups. Hold each other accountable, or compete to see who levels up fastest.'},
  {num:'Chapter V',glyph:'✦',title:'Begin your journey now',body:'Your quest log is ready. Your guild awaits.\nThe adventure starts now.'},
];

let current=0,autoTimer=null;

function render(idx){
  const c=chapters[idx];
  const el=document.getElementById('chapter-display');
  el.classList.remove('visible');
  setTimeout(()=>{
    document.getElementById('glyph').textContent=c.glyph;
    document.getElementById('ch-num').textContent=c.num;
    document.getElementById('ch-title').textContent=c.title;
    document.getElementById('ch-body').textContent=c.body;
    el.classList.add('visible');
  },320);
  document.querySelectorAll('.pip-nav').forEach((p,i)=>p.classList.toggle('active',i===idx));
  document.getElementById('prev-btn').disabled=idx===0;
  document.getElementById('next-btn').disabled=idx===chapters.length-1;
  document.getElementById('progress-line').style.width=Math.round((idx/(chapters.length-1))*100)+'%';
  spawnParticles();
}

function go(dir){
  clearTimeout(autoTimer);
  current=Math.max(0,Math.min(chapters.length-1,current+dir));
  render(current);
  scheduleAuto();
}

function scheduleAuto(){
  clearTimeout(autoTimer);
  if(current<chapters.length-1)autoTimer=setTimeout(()=>{current++;render(current);scheduleAuto();},4200);
}

const pipsEl=document.getElementById('pips');
chapters.forEach((_,i)=>{
  const p=document.createElement('div');
  p.className='pip-nav'+(i===0?' active':'');
  p.onclick=()=>{clearTimeout(autoTimer);current=i;render(i);scheduleAuto()};
  pipsEl.appendChild(p);
});

function spawnParticles(){
  const canvas=document.getElementById('particles-canvas');
  const stage=document.getElementById('stage');
  canvas.width=stage.offsetWidth;
  canvas.height=stage.offsetHeight;
  const ctx=canvas.getContext('2d');
  const pts=[];
  for(let i=0;i<18;i++){
    pts.push({x:Math.random()*canvas.width,y:Math.random()*canvas.height,r:Math.random()*1.2+0.3,vx:(Math.random()-0.5)*0.3,vy:-(Math.random()*0.4+0.1),life:0,maxLife:60+Math.random()*80});
  }
  let frame=0;
  function draw(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    pts.forEach(p=>{
      p.life++;p.x+=p.vx;p.y+=p.vy;
      const fade=p.life<20?p.life/20:Math.max(0,1-(p.life-20)/(p.maxLife-20));
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(201,168,76,${fade*0.7})`;ctx.fill();
    });
    if(++frame<120)requestAnimationFrame(draw);
  }
  draw();
}

render(0);
scheduleAuto();
</script>
